<controls:MetroWindow x:Class="wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:local="clr-namespace:wpf"
        mc:Ignorable="d"
        Title="UI Critic Studio" Height="780" Width="1320"
    FontFamily="Segoe UI Variable Text, Segoe UI"
    GlowBrush="{DynamicResource AccentColorBrush}"
    WindowStartupLocation="CenterScreen"
    WindowTitleBrush="#F4F7FB"
    NonActiveWindowTitleBrush="#F4F7FB"
    TitleForeground="Transparent"
    Background="#F4F7FB">

    <controls:MetroWindow.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <local:BoolToVisibilityInverseConverter x:Key="BoolToVisInv"/>
        <local:TruncateConverter x:Key="Truncate"/>
        <local:NonEmptyStringToVisibilityConverter x:Key="NonEmptyToVis"/>

        <SolidColorBrush x:Key="BgPanel" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BgCard" Color="#F8FAFD"/>
        <SolidColorBrush x:Key="Accent" Color="#0D6EFD"/>
        <SolidColorBrush x:Key="AccentHover" Color="#0B5ED7"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#1F2937"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#6C757D"/>
        <SolidColorBrush x:Key="BorderColor" Color="#DDE3EE"/>
        <SolidColorBrush x:Key="DangerColor" Color="#DC3545"/>
        <SolidColorBrush x:Key="TabIdle" Color="#EEF3FA"/>
        <SolidColorBrush x:Key="TabHover" Color="#E7EDF6"/>
        <SolidColorBrush x:Key="TabSelected" Color="#DCE5F0"/>
        <SolidColorBrush x:Key="StarFilled" Color="#F4C542"/>
        <SolidColorBrush x:Key="StarEmpty" Color="#B8941F"/>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,9"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentHover}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HistoryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BgCard}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="0,3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E7EEF9"/>
                                <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource BgCard}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="{StaticResource TextPrimary}"/>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BgCard}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="IconButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Padding" Value="10"/>
            <Setter Property="MinWidth" Value="40"/>
            <Setter Property="MinHeight" Value="40"/>
        </Style>

        <Style x:Key="DarkCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Margin" Value="0,4,0,4"/>
        </Style>

        <Style x:Key="DarkComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Background" Value="{StaticResource BgCard}"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#E7EEF9"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#D9E5F8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Background" Value="{StaticResource BgCard}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource DarkComboBoxItem}"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="ComboBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    SnapsToDevicePixels="True">
                                <ToggleButton Focusable="False"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                              ClickMode="Press">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="Transparent" BorderThickness="0">
                                                <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                                            </Border>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="28"/>
                                        </Grid.ColumnDefinitions>

                                        <ContentPresenter Grid.Column="0"
                                                          Margin="8,3,4,3"
                                                          HorizontalAlignment="Left"
                                                          VerticalAlignment="Center"
                                                          Content="{TemplateBinding SelectionBoxItem}"
                                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                          ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                          TextElement.Foreground="{TemplateBinding Foreground}"/>

                                        <Border Grid.Column="1"
                                                Background="#E7EEF9"
                                                CornerRadius="0,6,6,0"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="1,0,0,0">
                                            <Path Width="10"
                                                  Height="6"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Fill="{TemplateBinding Foreground}"
                                                  Data="M 0 0 L 10 0 L 5 6 Z"/>
                                        </Border>
                                    </Grid>
                                </ToggleButton>
                            </Border>

                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   PopupAnimation="Slide"
                                   Focusable="False">
                                <Border Margin="0,4,0,0"
                                        Background="{StaticResource BgCard}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer MaxHeight="260" CanContentScroll="True">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{StaticResource Accent}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{StaticResource Accent}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsModelComboBox" TargetType="ComboBox" BasedOn="{StaticResource DarkComboBox}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding ModelsMissing}" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource DangerColor}"/>
                    <Setter Property="Background" Value="#FDEDED"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TraitSlider" TargetType="Slider">
            <Setter Property="Foreground" Value="{StaticResource Accent}"/>
            <Setter Property="Background" Value="{StaticResource BorderColor}"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Margin" Value="0,2,8,2"/>
            <Setter Property="IsMoveToPointEnabled" Value="True"/>
        </Style>

        <Style x:Key="TraitValueText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Background" Value="#ECF2FC"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="MinWidth" Value="36"/>
            <Setter Property="Padding" Value="4,1"/>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="RoundedTabItem" TargetType="TabItem">
            <Setter Property="Background" Value="{StaticResource TabIdle}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10,10,0,0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource TabSelected}"/>
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{StaticResource BorderColor}"/>
                                <Setter Property="Panel.ZIndex" Value="1"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource TabHover}"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource TabSelected}"/>
                            </MultiTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </controls:MetroWindow.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" Foreground="{StaticResource TextPrimary}" ItemContainerStyle="{StaticResource RoundedTabItem}">
            <TabItem Header="Critique">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="360"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="10" Padding="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="PERSONNALITES" Style="{StaticResource SectionLabel}"/>
                            <TextBlock Grid.Row="1" Text="Selectionnez les profils de testeur a utiliser pour la critique." Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,10" TextWrapping="Wrap"/>
                            <Button Grid.Row="2" Content="Ajouter une personnalite" Style="{StaticResource SecondaryButton}" Command="{Binding AddPersonalityCommand}" Margin="0,0,0,10"/>

                            <Border Grid.Row="3" Background="{StaticResource BgCard}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="8" Padding="8">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding Personalities}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="6" Margin="0,0,0,6" Padding="8">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <Border x:Name="AvatarHost" Grid.Column="0" Width="34" Height="34" CornerRadius="17" Background="#E7EEF9" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" Margin="0,0,8,0" VerticalAlignment="Center">
                                                            <Grid>
                                                                <Image Source="{Binding AvatarImage}" Stretch="UniformToFill"/>
                                                                <Button x:Name="AvatarRefreshButton"
                                                                        Visibility="Collapsed"
                                                                        Background="#80FFFFFF"
                                                                        BorderThickness="0"
                                                                        Cursor="Hand"
                                                                        ToolTip="Regenerer l'avatar"
                                                                        Command="{Binding DataContext.RegenerateAvatarCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding}">
                                                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE72C;" Foreground="{StaticResource TextPrimary}" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Button>
                                                                <Grid x:Name="AvatarSpinner" Visibility="Collapsed" Background="#80FFFFFF">
                                                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE895;" Foreground="{StaticResource Accent}" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                                                        <TextBlock.RenderTransform>
                                                                            <RotateTransform Angle="0"/>
                                                                        </TextBlock.RenderTransform>
                                                                        <TextBlock.Triggers>
                                                                            <EventTrigger RoutedEvent="TextBlock.Loaded">
                                                                                <BeginStoryboard>
                                                                                    <Storyboard RepeatBehavior="Forever">
                                                                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(RotateTransform.Angle)" From="0" To="360" Duration="0:0:0.9"/>
                                                                                    </Storyboard>
                                                                                </BeginStoryboard>
                                                                            </EventTrigger>
                                                                        </TextBlock.Triggers>
                                                                    </TextBlock>
                                                                </Grid>
                                                            </Grid>
                                                        </Border>

                                                        <CheckBox Grid.Column="1" IsChecked="{Binding IsSelected, Mode=TwoWay}" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold" Content="{Binding Name}" VerticalAlignment="Center"/>
                                                        <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="8,0,0,0">
                                                            <Button Content="Editer" Style="{StaticResource SecondaryButton}"
                                                                    Command="{Binding DataContext.EditPersonalityCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="{Binding}"/>
                                                            <Button Content="Supprimer" Style="{StaticResource SecondaryButton}" Margin="6,0,0,0" Foreground="{StaticResource DangerColor}"
                                                                    Command="{Binding DataContext.DeletePersonalityCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="{Binding}"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                                <DataTemplate.Triggers>
                                                    <Trigger SourceName="AvatarHost" Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="AvatarRefreshButton" Property="Visibility" Value="Visible"/>
                                                    </Trigger>
                                                    <DataTrigger Binding="{Binding IsAvatarRefreshing}" Value="True">
                                                        <Setter TargetName="AvatarRefreshButton" Property="Visibility" Value="Collapsed"/>
                                                        <Setter TargetName="AvatarSpinner" Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>

                            <TextBlock Grid.Row="4" Text="{Binding SelectedPersonalitiesSummary}" Foreground="{StaticResource Accent}" FontSize="11" Margin="0,10,0,0" TextWrapping="Wrap"/>
                        </Grid>
                    </Border>

                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="300"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,10">
                            <TextBlock Text="CRITIQUE D'INTERFACE PAR IA" Foreground="{StaticResource Accent}" FontSize="20" FontWeight="Bold"/>
                            <TextBlock Text="Chargez un screenshot de l'application puis lancez la critique." Foreground="{StaticResource TextSecondary}" FontSize="12"/>
                        </StackPanel>

                        <Border Grid.Row="1" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="10" Margin="0,0,0,10">
                            <Grid>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding HasImage, Converter={StaticResource BoolToVisInv}}">
                                    <Button Style="{StaticResource IconButton}" Command="{Binding SelectImageCommand}" ToolTip="Choisir une image">
                                        <StackPanel>
                                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE898;" FontSize="34" HorizontalAlignment="Center" Foreground="{StaticResource Accent}"/>
                                            <TextBlock Text="JPG / PNG" Foreground="{StaticResource TextSecondary}" FontSize="11" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                                <Image Source="{Binding PreviewImage}" Stretch="Uniform" Visibility="{Binding HasImage, Converter={StaticResource BoolToVis}}" Margin="8"/>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10" VerticalAlignment="Center">
                            <Button Style="{StaticResource PrimaryButton}" Content="Choisir une image" Command="{Binding SelectImageCommand}" Margin="0,0,10,0"/>
                            <Button Style="{StaticResource PrimaryButton}" Content="Generer les critiques" Command="{Binding SendToApiCommand}" Margin="0,0,10,0"/>
                            <Button Style="{StaticResource SecondaryButton}" Content="Reset" Command="{Binding ResetCommand}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,10" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                            <ProgressBar IsIndeterminate="True" Width="180" Height="6" VerticalAlignment="Center"/>
                            <TextBlock Text="  Analyse en cours..." Foreground="{StaticResource Accent}" FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>

                        <Border Grid.Row="4" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="10">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                                <ItemsControl ItemsSource="{Binding Critiques}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Expander IsExpanded="{Binding IsExpanded, Mode=TwoWay}" Margin="0,0,0,8" Background="{StaticResource BgCard}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                                                <Expander.Header>
                                                    <DockPanel LastChildFill="False">
                                                        <TextBlock Text="{Binding PersonalityName}" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold" Margin="0,0,8,0"/>
                                                        <ItemsControl ItemsSource="{Binding StarStates}" ToolTip="{Binding RatingDisplay}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <StackPanel Orientation="Horizontal"/>
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <TextBlock Text="★" FontSize="15" Margin="0,0,2,0">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Foreground" Value="{StaticResource StarEmpty}"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding}" Value="True">
                                                                                        <Setter Property="Foreground" Value="{StaticResource StarFilled}"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </DockPanel>
                                                </Expander.Header>
                                                <Border Background="{StaticResource BgCard}" Padding="10">
                                                    <TextBlock Text="{Binding CritiqueText}" Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap"/>
                                                </Border>
                                            </Expander>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                    </Grid>

                    <Grid Grid.Column="4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="HISTORIQUE" Style="{StaticResource SectionLabel}"/>
                        <Border Grid.Row="1" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="10" Padding="8">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding HistoryEntries}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,3">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <Button Grid.Column="0" Style="{StaticResource HistoryButton}" Command="{Binding DataContext.RestoreHistoryCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding CreatedAt, StringFormat='Session du {0:dd/MM/yyyy HH:mm}'}" Foreground="{StaticResource Accent}" FontSize="11" FontWeight="SemiBold"/>
                                                        <ItemsControl ItemsSource="{Binding Ratings}" Margin="0,4,0,0">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <DockPanel LastChildFill="False" Margin="0,0,0,2">
                                                                        <TextBlock Text="{Binding PersonalityName}" Foreground="{StaticResource TextPrimary}" FontSize="11" Margin="0,0,8,0"/>
                                                                        <ItemsControl ItemsSource="{Binding StarStates}">
                                                                            <ItemsControl.ItemsPanel>
                                                                                <ItemsPanelTemplate>
                                                                                    <StackPanel Orientation="Horizontal"/>
                                                                                </ItemsPanelTemplate>
                                                                            </ItemsControl.ItemsPanel>
                                                                            <ItemsControl.ItemTemplate>
                                                                                <DataTemplate>
                                                                                    <TextBlock Text="★" FontSize="12" Margin="0,0,2,0">
                                                                                        <TextBlock.Style>
                                                                                            <Style TargetType="TextBlock">
                                                                                                <Setter Property="Foreground" Value="{StaticResource StarEmpty}"/>
                                                                                                <Style.Triggers>
                                                                                                    <DataTrigger Binding="{Binding}" Value="True">
                                                                                                        <Setter Property="Foreground" Value="{StaticResource StarFilled}"/>
                                                                                                    </DataTrigger>
                                                                                                </Style.Triggers>
                                                                                            </Style>
                                                                                        </TextBlock.Style>
                                                                                    </TextBlock>
                                                                                </DataTemplate>
                                                                            </ItemsControl.ItemTemplate>
                                                                        </ItemsControl>
                                                                    </DockPanel>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </Button>

                                                <Button Grid.Column="1" Content="X" Margin="4,3,0,3" Padding="8,4" Background="Transparent" Foreground="{StaticResource DangerColor}" BorderThickness="0" Cursor="Hand" ToolTip="Supprimer" Command="{Binding DataContext.DeleteHistoryCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Personalites">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Grid Margin="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="380"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,10,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="{Binding PersonalityFormTitle}" Foreground="{StaticResource Accent}" FontSize="20" FontWeight="Bold" Margin="0,0,0,12"/>

                            <TextBlock Grid.Row="1" Text="Nom" Style="{StaticResource SectionLabel}"/>
                            <TextBox Grid.Row="2" Style="{StaticResource DarkTextBox}" Text="{Binding PersonalityEditorName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

                            <TextBlock Grid.Row="3" Text="Description du testeur" Style="{StaticResource SectionLabel}"/>
                            <TextBox Grid.Row="4" Style="{StaticResource DarkTextBox}" Text="{Binding PersonalityEditorRole, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="70" Margin="0,0,0,10"/>

                            <TextBlock Grid.Row="5" Text="Traits du testeur (sliders)" Style="{StaticResource SectionLabel}"/>

                            <Grid Grid.Row="6" Margin="0,0,0,10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="44"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Curiosite" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                                <Slider Grid.Row="0" Grid.Column="1" Style="{StaticResource TraitSlider}" Minimum="0" Maximum="100" Value="{Binding EditorCuriosity, Mode=TwoWay}"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding EditorCuriosity}" Style="{StaticResource TraitValueText}" HorizontalAlignment="Right"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Competence" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                                <Slider Grid.Row="1" Grid.Column="1" Style="{StaticResource TraitSlider}" Minimum="0" Maximum="100" Value="{Binding EditorCompetence, Mode=TwoWay}"/>
                                <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding EditorCompetence}" Style="{StaticResource TraitValueText}" HorizontalAlignment="Right"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Praticite" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                                <Slider Grid.Row="2" Grid.Column="1" Style="{StaticResource TraitSlider}" Minimum="0" Maximum="100" Value="{Binding EditorPracticality, Mode=TwoWay}"/>
                                <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding EditorPracticality}" Style="{StaticResource TraitValueText}" HorizontalAlignment="Right"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Esthetique" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                                <Slider Grid.Row="3" Grid.Column="1" Style="{StaticResource TraitSlider}" Minimum="0" Maximum="100" Value="{Binding EditorAestheticSensitivity, Mode=TwoWay}"/>
                                <TextBlock Grid.Row="3" Grid.Column="2" Text="{Binding EditorAestheticSensitivity}" Style="{StaticResource TraitValueText}" HorizontalAlignment="Right"/>

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Rigueur" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                                <Slider Grid.Row="4" Grid.Column="1" Style="{StaticResource TraitSlider}" Minimum="0" Maximum="100" Value="{Binding EditorRigor, Mode=TwoWay}"/>
                                <TextBlock Grid.Row="4" Grid.Column="2" Text="{Binding EditorRigor}" Style="{StaticResource TraitValueText}" HorizontalAlignment="Right"/>
                            </Grid>

                            <TextBlock Grid.Row="7" Text="Flags utilisateur" Style="{StaticResource SectionLabel}"/>
                            <StackPanel Grid.Row="8" Margin="0,0,0,10">
                                <CheckBox Style="{StaticResource DarkCheckBox}" Content="Vision limitee" IsChecked="{Binding EditorLimitedVisionFlag, Mode=TwoWay}"/>
                                <CheckBox Style="{StaticResource DarkCheckBox}" Content="Personne agee" IsChecked="{Binding EditorElderlyFlag, Mode=TwoWay}"/>
                                <CheckBox Style="{StaticResource DarkCheckBox}" Content="Motricite reduite" IsChecked="{Binding EditorLowMobilityFlag, Mode=TwoWay}"/>
                                <CheckBox Style="{StaticResource DarkCheckBox}" Content="Faible aisance numerique" IsChecked="{Binding EditorLowDigitalLiteracyFlag, Mode=TwoWay}"/>
                            </StackPanel>

                            <TextBlock Grid.Row="9" Text="Personnalite finale" Style="{StaticResource SectionLabel}"/>
                            <TextBox Grid.Row="10" Style="{StaticResource DarkTextBox}" Text="{Binding PersonalityEditorFinal, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="120" Margin="0,0,0,10"/>

                            <StackPanel Grid.Row="11" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,10">
                                <Button Style="{StaticResource SecondaryButton}" Content="AI Generer" Command="{Binding GeneratePersonalityCommand}" Margin="0,0,10,0"/>
                                <Border Width="42" Height="42" CornerRadius="21" Background="#E7EEF9" BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                                    <Image Source="{Binding EditorAvatarImage}" Stretch="UniformToFill"/>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Row="13" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Style="{StaticResource SecondaryButton}" Content="Annuler" Command="{Binding CancelPersonalityCommand}" Margin="0,0,8,0"/>
                                <Button Style="{StaticResource PrimaryButton}" Content="Enregistrer" Command="{Binding SavePersonalityCommand}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="10" Padding="12">
                        <StackPanel>
                            <TextBlock Text="Conseils" Style="{StaticResource SectionLabel}"/>
                            <TextBlock Text="- Donnez un nom memorable a la personnalite." Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,0,0,6"/>
                            <TextBlock Text="- La description est optionnelle si le nom et les sliders suffisent a definir le profil." Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,0,0,6"/>
                            <TextBlock Text="- Ajustez les sliders pour simuler des styles de testeurs differents." Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,0,0,6"/>
                            <TextBlock Text="- Activez les flags pour simuler des contraintes reelles d'usage." Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,0,0,6"/>
                        </StackPanel>
                    </Border>
                </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Parametres">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Grid Margin="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="340"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,10,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Configuration" Foreground="{StaticResource Accent}" FontSize="20" FontWeight="Bold" Margin="0,0,0,12"/>

                            <TextBlock Grid.Row="1" Text="Cle API GitHub PAT" Style="{StaticResource SectionLabel}"/>
                            <TextBox Grid.Row="2"
                                     Text="{Binding ApiKeyInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,6">
                                <TextBox.Style>
                                    <Style TargetType="TextBox" BasedOn="{StaticResource DarkTextBox}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ApiKeyMissing}" Value="True">
                                                <Setter Property="BorderBrush" Value="{StaticResource DangerColor}"/>
                                                <Setter Property="Background" Value="#FDEDED"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>

                            <TextBlock Grid.Row="3"
                                       Text="Aucune clé API détectée dans .env."
                                       Foreground="{StaticResource DangerColor}"
                                       Margin="0,0,0,10"
                                       Visibility="{Binding ApiKeyMissing, Converter={StaticResource BoolToVis}}"/>

                            <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,0,0,14">
                                <Button Content="Valider la clé"
                                        Style="{StaticResource PrimaryButton}"
                                        Command="{Binding ValidateApiKeyCommand}"/>
                                <TextBlock Text="{Binding ApiKeyValidationError}"
                                           Foreground="{StaticResource DangerColor}"
                                           VerticalAlignment="Center"
                                           Margin="12,0,0,0"
                                           TextWrapping="Wrap"
                                           Visibility="{Binding ApiKeyValidationError, Converter={StaticResource NonEmptyToVis}}"/>
                            </StackPanel>

                            <TextBlock Grid.Row="5" Text="Modele IA" Style="{StaticResource SectionLabel}"/>
                            <ComboBox Grid.Row="6"
                                      Width="320"
                                      HorizontalAlignment="Left"
                                      ItemsSource="{Binding AvailableModels}"
                                      SelectedItem="{Binding SelectedModel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      Style="{StaticResource SettingsModelComboBox}"
                                      Margin="0,0,0,6">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" Foreground="{StaticResource TextPrimary}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                                <ComboBox.Resources>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#FFFFFF"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#FFFFFF"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.ControlLightBrushKey}" Color="#E7EEF9"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.ControlLightLightBrushKey}" Color="#E7EEF9"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#1F2937"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#1F2937"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#D9E5F8"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#1F2937"/>
                                </ComboBox.Resources>
                            </ComboBox>

                            <TextBlock Grid.Row="7"
                                       Text="Aucun modele trouvé dans .env. Configurez MODEL_NAMES ou MODEL_NAME."
                                       Foreground="{StaticResource DangerColor}"
                                       Margin="0,0,0,10"
                                       Visibility="{Binding ModelsMissing, Converter={StaticResource BoolToVis}}"/>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="10" Padding="12">
                        <StackPanel>
                            <TextBlock Text="Aide" Style="{StaticResource SectionLabel}"/>
                            <TextBlock Text="- Le champ de clé API est prérempli si GITHUB_PAT est trouvé dans .env." Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,0,0,6"/>
                            <TextBlock Text="- Si la clé ou les modèles sont absents, les champs deviennent rouges." Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,0,0,6"/>
                            <TextBlock Text="- Au démarrage, l'application ouvre cet onglet automatiquement quand la configuration est incomplète." Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,0,0,6"/>
                        </StackPanel>
                    </Border>
                </Grid>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Status bar -->
        <Border Grid.Row="1" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,0" Margin="-16,12,-16,-16" Padding="16,8">
            <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource TextSecondary}" FontSize="12"/>
        </Border>
    </Grid>
</controls:MetroWindow>
