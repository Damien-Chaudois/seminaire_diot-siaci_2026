<Window x:Class="wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:wpf"
        mc:Ignorable="d"
        Title="UI Critic Studio" Height="780" Width="1320"
        Background="#1B1C24">

    <Window.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <local:BoolToVisibilityInverseConverter x:Key="BoolToVisInv"/>
        <local:TruncateConverter x:Key="Truncate"/>

        <SolidColorBrush x:Key="BgPanel" Color="#262A38"/>
        <SolidColorBrush x:Key="BgCard" Color="#31384B"/>
        <SolidColorBrush x:Key="Accent" Color="#F08A4B"/>
        <SolidColorBrush x:Key="AccentHover" Color="#F4A676"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#F3F5FB"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#B3BCD3"/>
        <SolidColorBrush x:Key="BorderColor" Color="#444F69"/>
        <SolidColorBrush x:Key="DangerColor" Color="#EF6F6C"/>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,9"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentHover}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HistoryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BgCard}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="0,3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3A4360"/>
                                <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource BgCard}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="{StaticResource TextPrimary}"/>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="14"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="14"/>
            <ColumnDefinition Width="360"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Left: personalities -->
        <Border Grid.Column="0" Grid.Row="0" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="10" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="PERSONNALITES" Style="{StaticResource SectionLabel}"/>
                <TextBlock Grid.Row="1" Text="Selectionnez une ou plusieurs personnalites d'analyse." Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,10" TextWrapping="Wrap"/>

                <Border Grid.Row="2" Background="#222838" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="8" Padding="8">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Personalities}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="6" Margin="0,0,0,6" Padding="8">
                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold" Content="{Binding Name}"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <TextBlock Grid.Row="3" Text="{Binding SelectedPersonalitiesSummary}" Foreground="{StaticResource Accent}" FontSize="11" Margin="0,10,0,0" TextWrapping="Wrap"/>
            </Grid>
        </Border>

        <!-- Center: upload + result -->
        <Grid Grid.Column="2" Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="310"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,10">
                <TextBlock Text="CRITIQUE D'INTERFACE PAR IA" Foreground="{StaticResource Accent}" FontSize="20" FontWeight="Bold"/>
                <TextBlock Text="Chargez un screenshot de l'application, puis lancez une critique par personnalite." Foreground="{StaticResource TextSecondary}" FontSize="12"/>
            </StackPanel>

            <Border Grid.Row="1" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="10" Margin="0,0,0,10">
                <Grid>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding HasImage, Converter={StaticResource BoolToVisInv}}">
                        <TextBlock Text="Aucune image selectionnee" Foreground="{StaticResource TextSecondary}"/>
                        <TextBlock Text="Formats acceptes : JPG / PNG" Foreground="{StaticResource TextSecondary}" FontSize="11" HorizontalAlignment="Center"/>
                    </StackPanel>
                    <Image Source="{Binding PreviewImage}" Stretch="Uniform" Visibility="{Binding HasImage, Converter={StaticResource BoolToVis}}" Margin="8"/>
                </Grid>
            </Border>

            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
                <Button Style="{StaticResource PrimaryButton}" Content="Choisir une image" Command="{Binding SelectImageCommand}" Margin="0,0,10,0"/>
                <Button Style="{StaticResource PrimaryButton}" Content="Generer les critiques" Command="{Binding SendToApiCommand}"/>
            </StackPanel>

            <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,10" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                <ProgressBar IsIndeterminate="True" Width="180" Height="6" VerticalAlignment="Center"/>
                <TextBlock Text="  Analyse en cours..." Foreground="{StaticResource Accent}" FontSize="12" VerticalAlignment="Center"/>
            </StackPanel>

            <Border Grid.Row="4" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="10">
                <Grid>
                    <TextBox Background="Transparent" Foreground="{StaticResource TextPrimary}" BorderThickness="0" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Text="{Binding ResultText}" Padding="10"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Right: history -->
        <Grid Grid.Column="4" Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="HISTORIQUE" Style="{StaticResource SectionLabel}"/>

            <Border Grid.Row="1" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="10" Padding="8">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding HistoryEntries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0" Style="{StaticResource HistoryButton}" Command="{Binding DataContext.RestoreHistoryCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding CreatedAt, StringFormat='Session du {0:dd/MM/yyyy HH:mm}'}" Foreground="{StaticResource Accent}" FontSize="11" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding SelectedPersonalitiesCsv}" Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding ResultText, Converter={StaticResource Truncate}, ConverterParameter=80}" Foreground="{StaticResource TextPrimary}" FontSize="12" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </Button>

                                    <Button Grid.Column="1" Content="X" Margin="4,3,0,3" Padding="8,4" Background="Transparent" Foreground="{StaticResource DangerColor}" BorderThickness="0" Cursor="Hand" ToolTip="Supprimer" Command="{Binding DataContext.DeleteHistoryCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Column="0" Grid.ColumnSpan="5" Grid.Row="1" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,0" Margin="-16,12,-16,-16" Padding="16,8">
            <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource TextSecondary}" FontSize="12"/>
        </Border>
    </Grid>
</Window>
